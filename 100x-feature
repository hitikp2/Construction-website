/* ══════════════════════ ROI CALCULATOR ══════════════════════ */
function calcROI(){
  const sqft=parseInt(document.getElementById('roiSqft').value)||600;
  const county=document.getElementById('roiCounty').value;
  const tier=document.getElementById('roiTier').value;
  const rent=parseInt(document.getElementById('roiRent').value)||2200;
  const term=parseInt(document.getElementById('roiTerm').value)||120;
  const cm={la:1.12,sb:1.0,oc:1.15,rv:.95};
  const tm={standard:250,mid:350,premium:500};
  const cost=Math.round(sqft*tm[tier]*(cm[county]||1));
  const annual=rent*12;
  const rate=0.065/12;
  const pmt=Math.round(cost*(rate*Math.pow(1+rate,term))/(Math.pow(1+rate,term)-1));
  const cashflow=rent-pmt;
  const payback=(cost/annual).toFixed(1);
  document.getElementById('roiBuildCost').textContent='$'+cost.toLocaleString();
  document.getElementById('roiMonthlyRent').textContent='$'+rent.toLocaleString()+'/mo';
  document.getElementById('roiAnnualIncome').textContent='$'+annual.toLocaleString()+'/yr';
  document.getElementById('roiMonthlyPmt').textContent='$'+pmt.toLocaleString()+'/mo';
  document.getElementById('roiCashflow').textContent='$'+cashflow.toLocaleString();
  document.getElementById('roiPayback').textContent=payback+' yrs';
  for(let y=1;y<=5;y++){
    const cumulative=annual*y;
    const pctFill=Math.min(95,Math.round((cumulative/cost)*100));
    document.querySelectorAll('.roi-bar-fill')[y-1].style.width=pctFill+'%';
    document.getElementById('roiY'+y).textContent='$'+(Math.round(cumulative/1000))+'K';
  }
  document.getElementById('roiResult').classList.add('show');
}
calcROI();
</script>

