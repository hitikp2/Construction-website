<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>100x Features — X Construction</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#060606;--bg2:#0d0d0d;--bg3:#151515;--bg4:#1e1e1e;
  --surface:#111;--surface2:#191919;--surface3:#222;
  --text:#f0efe9;--text2:#a8a8a0;--text3:#5e5e58;
  --accent:#c8ff00;--accent2:#a8d900;--glow:rgba(200,255,0,.12);
  --warm:#ff6b35;--blue:#00b4d8;--violet:#9b5de5;--gold:#ffd60a;--green:#22c55e;--red:#ef4444;
  --font:'Outfit',sans-serif;--fd:'Playfair Display',serif;--fm:'JetBrains Mono',monospace;
  --r:12px;--rl:20px;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--font);background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.6}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
input,textarea,select{font-family:inherit;outline:none}
ul{list-style:none}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:99px}
.container{max-width:1280px;margin:0 auto;padding:0 24px}
.section{padding:100px 0;position:relative}
.section-alt{background:var(--bg2)}
.slabel{font-family:var(--fm);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.slabel::before{content:'';width:20px;height:1px;background:var(--accent)}
.stitle{font-family:var(--fd);font-size:clamp(1.8rem,4vw,3rem);line-height:1.1;margin-bottom:14px}
.stitle em{color:var(--accent);font-style:italic}
.ssub{color:var(--text3);font-size:.95rem;max-width:560px;line-height:1.7;margin-bottom:40px}
.btn{display:inline-flex;align-items:center;gap:7px;padding:12px 26px;border-radius:99px;font-weight:600;font-size:.85rem;transition:all .25s ease}
.btn-p{background:var(--accent);color:var(--bg);box-shadow:0 0 30px rgba(200,255,0,.12)}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 0 50px rgba(200,255,0,.25)}
.btn-o{border:1.5px solid rgba(200,255,0,.3);color:var(--accent)}
.btn-o:hover{background:rgba(200,255,0,.05)}
.btn-s{padding:8px 16px;font-size:.75rem}
.fade-in{opacity:0;transform:translateY(25px);transition:opacity .6s ease,transform .6s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}
.divider-line{width:100%;height:1px;background:linear-gradient(90deg,transparent,rgba(200,255,0,.08),transparent);margin:0}
.tag{padding:3px 10px;border-radius:99px;font-size:.62rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;display:inline-flex;align-items:center;gap:4px}
.tag-green{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.15)}
.tag-accent{background:rgba(200,255,0,.08);color:var(--accent);border:1px solid rgba(200,255,0,.1)}
.tag-blue{background:rgba(0,180,216,.08);color:var(--blue);border:1px solid rgba(0,180,216,.12)}
.tag-violet{background:rgba(155,93,229,.08);color:var(--violet);border:1px solid rgba(155,93,229,.12)}
.tag-gold{background:rgba(255,214,10,.08);color:var(--gold);border:1px solid rgba(255,214,10,.12)}

/* ══════════════════════════════════════════════

1. CLIENT PORTAL DEMO
   ══════════════════════════════════════════════ */
   .portal-grid{display:grid;grid-template-columns:1fr 1.5fr;gap:32px;align-items:start}
   @media(max-width:900px){.portal-grid{grid-template-columns:1fr}}
   .portal-demo{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–rl);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.4)}
   .portal-bar{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(–bg3);border-bottom:1px solid rgba(255,255,255,.04)}
   .portal-dot{width:8px;height:8px;border-radius:50%}
   .portal-bar-title{font-size:.72rem;color:var(–text3);margin-left:8px;font-weight:500}
   .portal-nav{display:flex;border-bottom:1px solid rgba(255,255,255,.04)}
   .portal-nav button{flex:1;padding:10px 8px;font-size:.7rem;font-weight:600;color:var(–text3);border-bottom:2px solid transparent;transition:all .2s}
   .portal-nav button.active{color:var(–accent);border-bottom-color:var(–accent)}
   .portal-nav button:hover{color:var(–text2)}
   .portal-body{padding:18px}
   .portal-panel{display:none}
   .portal-panel.active{display:block}

/* Progress tracker */
.progress-track{display:flex;gap:0;margin-bottom:20px;position:relative}
.progress-track::before{content:’’;position:absolute;top:14px;left:24px;right:24px;height:2px;background:var(–bg3)}
.progress-step{flex:1;text-align:center;position:relative;z-index:1}
.progress-step .dot{width:28px;height:28px;border-radius:50%;margin:0 auto 6px;display:grid;place-items:center;font-size:.65rem;font-weight:700;border:2px solid var(–bg3);background:var(–bg);color:var(–text3);transition:all .3s}
.progress-step.done .dot{background:var(–accent);border-color:var(–accent);color:var(–bg)}
.progress-step.current .dot{border-color:var(–accent);color:var(–accent);box-shadow:0 0 12px rgba(200,255,0,.25)}
.progress-step .lbl{font-size:.58rem;color:var(–text3)}
.progress-step.done .lbl,.progress-step.current .lbl{color:var(–text2)}

/* Photo feed */
.photo-feed{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:12px}
.photo-feed-item{aspect-ratio:4/3;border-radius:8px;overflow:hidden;position:relative;background:var(–bg3)}
.photo-feed-item img{width:100%;height:100%;object-fit:cover;filter:brightness(.85)}
.photo-feed-item .date{position:absolute;bottom:4px;right:6px;font-size:.55rem;color:rgba(255,255,255,.5);font-family:var(–fm)}

/* Budget tracker */
.budget-bar{margin:12px 0}
.budget-header{display:flex;justify-content:space-between;font-size:.75rem;margin-bottom:6px}
.budget-header .spent{color:var(–accent);font-weight:600;font-family:var(–fm)}
.budget-header .total{color:var(–text3)}
.budget-track{height:8px;background:var(–bg3);border-radius:99px;overflow:hidden}
.budget-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(–accent),var(–gold));transition:width 1.5s ease}
.budget-items{margin-top:10px;display:flex;flex-direction:column;gap:4px}
.budget-row{display:flex;justify-content:space-between;font-size:.72rem;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.budget-row .cat{color:var(–text2)}
.budget-row .amt{font-family:var(–fm);font-weight:500}
.budget-row .amt.over{color:var(–red)}

/* Documents */
.doc-list{display:flex;flex-direction:column;gap:6px;margin-top:8px}
.doc-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(–bg3);border-radius:8px;font-size:.75rem;transition:background .2s}
.doc-item:hover{background:var(–bg4)}
.doc-item .ico{font-size:1rem}
.doc-item .name{flex:1;font-weight:500}
.doc-item .size{color:var(–text3);font-size:.65rem;font-family:var(–fm)}

/* Messages */
.msg-thread{display:flex;flex-direction:column;gap:8px;margin-top:8px;max-height:200px;overflow-y:auto}
.msg{display:flex;gap:8px;align-items:flex-start}
.msg-avatar{width:26px;height:26px;border-radius:50%;display:grid;place-items:center;font-size:.6rem;font-weight:700;flex-shrink:0}
.msg-avatar.pm{background:rgba(200,255,0,.1);color:var(–accent)}
.msg-avatar.client{background:rgba(0,180,216,.1);color:var(–blue)}
.msg-bubble{background:var(–bg3);border-radius:10px;padding:8px 10px;font-size:.75rem;line-height:1.5;max-width:85%}
.msg-time{font-size:.55rem;color:var(–text3);margin-top:2px;font-family:var(–fm)}

/* ══════════════════════════════════════════════
2. AI SCOPING WIZARD
══════════════════════════════════════════════ */
.wizard-container{max-width:700px;margin:0 auto}
.wizard-box{background:var(–surface);border:1px solid rgba(200,255,0,.06);border-radius:var(–rl);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.4)}
.wizard-progress{display:flex;padding:14px 20px;background:var(–bg3);gap:4px}
.wizard-pip{flex:1;height:3px;border-radius:99px;background:var(–bg4);transition:background .3s}
.wizard-pip.done{background:var(–accent)}
.wizard-pip.current{background:var(–accent);box-shadow:0 0 8px rgba(200,255,0,.3)}
.wizard-step{padding:28px 24px;display:none}
.wizard-step.active{display:block}
.wizard-q{font-size:1.1rem;font-weight:700;margin-bottom:4px}
.wizard-hint{font-size:.78rem;color:var(–text3);margin-bottom:20px}
.wizard-options{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px}
.wizard-opt{padding:14px 12px;border:1.5px solid rgba(255,255,255,.06);border-radius:var(–r);text-align:center;cursor:pointer;transition:all .2s;font-size:.82rem;font-weight:500;color:var(–text2)}
.wizard-opt:hover{border-color:rgba(200,255,0,.2);background:rgba(200,255,0,.02)}
.wizard-opt.selected{border-color:var(–accent);background:rgba(200,255,0,.05);color:var(–accent)}
.wizard-opt .ico{font-size:1.4rem;margin-bottom:6px;display:block}
.wizard-nav{display:flex;gap:10px;margin-top:24px}
.wizard-nav .btn{flex:1;justify-content:center}
/* Wizard result */
.wizard-result{padding:28px 24px;display:none}
.wizard-result.active{display:block}
.wr-header{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.wr-icon{width:48px;height:48px;border-radius:12px;background:rgba(200,255,0,.08);display:grid;place-items:center;font-size:1.5rem}
.wr-title{font-size:1.1rem;font-weight:700}
.wr-sub{font-size:.78rem;color:var(–text3)}
.wr-section{margin-bottom:16px}
.wr-section-title{font-size:.72rem;color:var(–text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;font-family:var(–fm)}
.wr-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.wr-item{display:flex;justify-content:space-between;padding:8px 12px;background:var(–bg3);border-radius:8px;font-size:.82rem}
.wr-item .cat{color:var(–text2)}
.wr-item .val{font-family:var(–fm);font-weight:600;color:var(–accent)}
.wr-total{display:flex;justify-content:space-between;padding:14px 16px;background:rgba(200,255,0,.05);border:1px solid rgba(200,255,0,.1);border-radius:var(–r);margin-top:12px}
.wr-total .cat{font-weight:700;font-size:.95rem}
.wr-total .val{font-family:var(–fm);font-weight:800;font-size:1.2rem;color:var(–accent)}
.wr-mood{display:flex;gap:6px;margin-top:12px}
.wr-mood-item{flex:1;aspect-ratio:1;border-radius:10px;background:var(–bg3);display:grid;place-items:center;font-size:1.5rem;opacity:.5}

/* ══════════════════════════════════════════════
3. INTERACTIVE PROJECT MAP
══════════════════════════════════════════════ */
.map-container{position:relative;border-radius:var(–rl);overflow:hidden;background:var(–surface);border:1px solid rgba(255,255,255,.04);box-shadow:0 20px 60px rgba(0,0,0,.4)}
.map-viewport{position:relative;aspect-ratio:16/9;background:#0a0f0a;overflow:hidden}
/* SVG-based simplified SoCal map */
.map-svg{width:100%;height:100%}
.map-pin{cursor:pointer;transition:transform .2s ease}
.map-pin:hover{transform:scale(1.3)}
.map-pin circle.outer{fill:rgba(200,255,0,.15);stroke:none}
.map-pin circle.inner{fill:var(–accent);stroke:var(–bg);stroke-width:1.5}
.map-pin.active circle.outer{fill:rgba(200,255,0,.3);r:14}
.map-pin.active circle.inner{r:6}

/* Map popup */
.map-popup{position:absolute;z-index:20;background:var(–surface2);border:1px solid rgba(200,255,0,.1);border-radius:var(–r);padding:14px;width:260px;box-shadow:0 12px 40px rgba(0,0,0,.6);display:none;pointer-events:auto}
.map-popup.show{display:block}
.map-popup-close{position:absolute;top:8px;right:8px;width:22px;height:22px;border-radius:50%;background:var(–bg3);display:grid;place-items:center;font-size:.7rem;color:var(–text3)}
.map-popup h4{font-size:.9rem;font-weight:700;margin-bottom:2px}
.map-popup .meta{font-size:.7rem;color:var(–text3);margin-bottom:8px}
.map-popup .preview{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:8px}
.map-popup .preview-img{aspect-ratio:4/3;border-radius:6px;background:var(–bg3);display:grid;place-items:center;font-size:1rem;opacity:.4;position:relative;overflow:hidden}
.map-popup .preview-img .lbl{position:absolute;bottom:2px;left:4px;font-size:.5rem;color:rgba(255,255,255,.4);font-family:var(–fm)}
.map-popup .cost{font-family:var(–fm);color:var(–accent);font-weight:700;font-size:.85rem}
.map-popup .quote{font-style:italic;font-size:.72rem;color:var(–text2);margin-top:6px;line-height:1.5}

.map-filters{display:flex;gap:6px;padding:12px 16px;border-top:1px solid rgba(255,255,255,.04);flex-wrap:wrap}
.map-filter{padding:5px 14px;border-radius:99px;font-size:.7rem;font-weight:600;border:1px solid rgba(255,255,255,.06);color:var(–text3);cursor:pointer;transition:all .2s}
.map-filter.active,.map-filter:hover{border-color:var(–accent);color:var(–accent);background:rgba(200,255,0,.04)}
.map-legend{display:flex;gap:16px;padding:0 16px 12px;font-size:.65rem;color:var(–text3)}
.map-legend-item{display:flex;align-items:center;gap:4px}
.map-legend-dot{width:8px;height:8px;border-radius:50%}

/* ══════════════════════════════════════════════
4. PRICE TRANSPARENCY MATRIX
══════════════════════════════════════════════ */
.matrix-tabs{display:flex;gap:6px;margin-bottom:24px;flex-wrap:wrap}
.matrix-tab{padding:8px 18px;border-radius:99px;font-size:.78rem;font-weight:600;border:1px solid rgba(255,255,255,.06);color:var(–text3);cursor:pointer;transition:all .2s}
.matrix-tab.active{border-color:var(–accent);color:var(–accent);background:rgba(200,255,0,.04)}
.matrix-table{width:100%;border-collapse:separate;border-spacing:0;background:var(–surface);border-radius:var(–rl);overflow:hidden;border:1px solid rgba(255,255,255,.04)}
.matrix-table th{padding:14px 16px;text-align:left;font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;color:var(–text3);background:var(–bg3);font-family:var(–fm);font-weight:500;border-bottom:1px solid rgba(255,255,255,.04)}
.matrix-table th:not(:first-child){text-align:center}
.matrix-table td{padding:12px 16px;font-size:.82rem;border-bottom:1px solid rgba(255,255,255,.03);color:var(–text2)}
.matrix-table td:not(:first-child){text-align:center;font-family:var(–fm);font-size:.78rem}
.matrix-table tr:last-child td{border-bottom:none;font-weight:700;color:var(–text);background:rgba(200,255,0,.03);font-size:.9rem}
.matrix-table tr:last-child td:not(:first-child){color:var(–accent)}
.matrix-table tr:hover td{background:rgba(255,255,255,.01)}
.matrix-table .tier-header{font-weight:700;color:var(–text)}
.tier-standard{color:var(–text2)}
.tier-mid{color:var(–gold)}
.tier-premium{color:var(–accent)}
.matrix-includes{margin-top:20px;display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:600px){.matrix-includes{grid-template-columns:1fr}}
.matrix-inc-card{padding:16px;background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–r)}
.matrix-inc-card h5{font-size:.78rem;font-weight:700;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.matrix-inc-card ul{font-size:.78rem;color:var(–text3);line-height:2}
.matrix-inc-card ul li::before{content:’✓ ’;color:var(–green)}
.matrix-exc-card ul li::before{content:’✕ ’;color:var(–red)}

/* ══════════════════════════════════════════════
5. MEET YOUR PM
══════════════════════════════════════════════ */
.pm-container{max-width:640px;margin:0 auto}
.pm-card{background:var(–surface);border:1px solid rgba(200,255,0,.08);border-radius:var(–rl);padding:32px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.4)}
.pm-success{font-size:2.5rem;margin-bottom:12px}
.pm-card h3{font-size:1.2rem;font-weight:700;margin-bottom:4px}
.pm-card .subtitle{color:var(–text3);font-size:.85rem;margin-bottom:24px}
.pm-profile{display:flex;align-items:center;gap:20px;padding:20px;background:var(–bg3);border-radius:var(–r);text-align:left;margin-bottom:20px}
.pm-avatar{width:72px;height:72px;border-radius:50%;background:rgba(200,255,0,.08);border:2px solid rgba(200,255,0,.15);display:grid;place-items:center;font-size:1.6rem;font-weight:800;color:var(–accent);font-family:var(–fm);flex-shrink:0}
.pm-info h4{font-size:1.05rem;font-weight:700;margin-bottom:2px}
.pm-info .role{color:var(–accent);font-size:.78rem;font-weight:600;margin-bottom:6px}
.pm-info .bio{color:var(–text3);font-size:.78rem;line-height:1.5}
.pm-stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:20px}
.pm-stat{padding:12px;background:var(–bg3);border-radius:8px;text-align:center}
.pm-stat .num{font-family:var(–fm);font-size:1.1rem;font-weight:700;color:var(–accent)}
.pm-stat .lbl{font-size:.65rem;color:var(–text3);margin-top:2px}
.pm-certs{display:flex;justify-content:center;gap:6px;margin-bottom:20px;flex-wrap:wrap}
.pm-cert{font-size:.62rem;padding:4px 10px;background:rgba(200,255,0,.05);border:1px solid rgba(200,255,0,.08);border-radius:99px;color:var(–accent)}
.pm-actions{display:flex;gap:8px}
.pm-actions .btn{flex:1;justify-content:center}

/* ══════════════════════════════════════════════
6. LIVE BUILD FEED
══════════════════════════════════════════════ */
.live-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:32px}
@media(max-width:768px){.live-grid{grid-template-columns:1fr}}
.live-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–rl);overflow:hidden;transition:all .3s}
.live-card:hover{border-color:rgba(200,255,0,.1);transform:translateY(-2px)}
.live-card-img{aspect-ratio:16/9;background:var(–bg3);position:relative;overflow:hidden;display:grid;place-items:center}
.live-card-img .emoji{font-size:2.5rem;opacity:.3}
.live-badge{position:absolute;top:8px;left:8px}
.live-card-body{padding:16px}
.live-card-body h4{font-size:.92rem;font-weight:700;margin-bottom:4px}
.live-card-body .loc{font-size:.72rem;color:var(–text3);margin-bottom:12px}
.live-progress{margin-bottom:8px}
.live-progress-header{display:flex;justify-content:space-between;font-size:.7rem;margin-bottom:4px}
.live-progress-header .phase{color:var(–accent);font-weight:600}
.live-progress-header .week{color:var(–text3)}
.live-progress-bar{height:4px;background:var(–bg3);border-radius:99px;overflow:hidden}
.live-progress-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(–accent),var(–gold))}
.live-card-footer{display:flex;justify-content:space-between;align-items:center;font-size:.72rem;color:var(–text3);padding-top:8px;border-top:1px solid rgba(255,255,255,.03)}
.live-card-footer .cost{font-family:var(–fm);color:var(–accent);font-weight:600}

/* ══════════════════════════════════════════════
7. ADU ROI CALCULATOR
══════════════════════════════════════════════ */
.roi-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}
@media(max-width:900px){.roi-grid{grid-template-columns:1fr}}
.roi-form{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–rl);padding:28px}
.roi-group{margin-bottom:14px}
.roi-group label{display:block;font-size:.72rem;color:var(–text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;font-weight:500}
.roi-group input,.roi-group select{width:100%;background:var(–bg3);border:1px solid rgba(255,255,255,.05);border-radius:var(–r);padding:10px 14px;color:var(–text);font-size:.85rem}
.roi-group select option{background:var(–bg2)}
.roi-group input:focus,.roi-group select:focus{border-color:rgba(200,255,0,.25)}
.roi-result{background:var(–surface);border:1px solid rgba(200,255,0,.08);border-radius:var(–rl);padding:28px;display:none}
.roi-result.show{display:block}
.roi-hero-stat{text-align:center;margin-bottom:20px;padding:20px;background:rgba(200,255,0,.03);border-radius:var(–r);border:1px solid rgba(200,255,0,.06)}
.roi-hero-stat .val{font-family:var(–fm);font-size:2.4rem;font-weight:800;color:var(–accent)}
