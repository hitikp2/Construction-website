    <div class="wr-item"><span class="cat">County</span><span class="val">${{la:'Los Angeles',sb:'San Bernardino',oc:'Orange County',rv:'Riverside'}[county]}</span></div>
    <div class="wr-item"><span class="cat">Tier</span><span class="val">${{standard:'Standard',mid:'Mid-Range',premium:'Premium'}[wizData.tier||'mid']}</span></div>`;
  document.getElementById('wizBreakdown').innerHTML=`
    <div class="wr-item"><span class="cat">Materials & Finishes</span><span class="val">$${m.toLocaleString()}</span></div>
    <div class="wr-item"><span class="cat">Skilled Labor</span><span class="val">$${l.toLocaleString()}</span></div>
