/* ══════════════════════ WIZARD ══════════════════════ */
const wizData={room:'',style:'',counter:'',tier:'mid'};
function wizSelect(el,key,val){
  wizData[key]=val;
  el.parentElement.querySelectorAll('.wizard-opt').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
}
function wizNext(step){
  document.querySelectorAll('.wizard-step').forEach(s=>s.classList.remove('active'));
  const s=document.getElementById('ws'+step);
  if(s)s.classList.add('active');
  document.querySelectorAll('.wizard-pip').forEach((p,i)=>{
    p.classList.remove('done','current');
    if(i<step-1)p.classList.add('done');
    if(i===step-1)p.classList.add('current');
  });
}
function wizGenerate(){
  document.querySelectorAll('.wizard-step').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.wizard-pip').forEach(p=>p.classList.add('done'));
  const sqft=parseInt(document.getElementById('wizSqft').value)||200;
  const county=document.getElementById('wizCounty').value;
  const cm={la:1.12,sb:1.0,oc:1.15,rv:.95};
  const tm={standard:250,mid:350,premium:550};
  const rate=tm[wizData.tier||'mid'];
  const total=Math.round(sqft*rate*(cm[county]||1));
  const m=Math.round(total*.4),l=Math.round(total*.32),d=Math.round(total*.08),p=Math.round(total*.08),pm=Math.round(total*.12);
  document.getElementById('wizSelections').innerHTML=`
    <div class="wr-item"><span class="cat">Room</span><span class="val">${(wizData.room||'kitchen').charAt(0).toUpperCase()+(wizData.room||'kitchen').slice(1)}</span></div>
    <div class="wr-item"><span class="cat">Style</span><span class="val">${(wizData.style||'modern').charAt(0).toUpperCase()+(wizData.style||'modern').slice(1)}</span></div>
    <div class="wr-item"><span class="cat">Countertop</span><span class="val">${(wizData.counter||'quartz').charAt(0).toUpperCase()+(wizData.counter||'quartz').slice(1)}</span></div>
