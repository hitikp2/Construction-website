<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0a0a0a;--bg2:#111;--bg3:#1a1a1a;--bg4:#222;
  --surface:#161616;--surface2:#1e1e1e;
  --text:#f0efe9;--text2:#a8a8a0;--text3:#6a6a64;
  --accent:#c8ff00;--accent2:#a8d900;--accent-glow:rgba(200,255,0,.15);
  --warm:#ff6b35;--blue:#00b4d8;--violet:#9b5de5;
  --gold:#ffd60a;--green:#22c55e;--red:#ef4444;
  --radius:12px;--radius-lg:20px;
  --font:'Outfit',sans-serif;--font-display:'Playfair Display',serif;--font-mono:'JetBrains Mono',monospace;
  --transition:all .3s cubic-bezier(.4,0,.2,1);
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--font);background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.6}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
input,textarea,select{font-family:inherit;outline:none}
ul{list-style:none}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:99px}
.container{max-width:1320px;margin:0 auto;padding:0 24px}
.section{padding:120px 0}
.section-label{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.section-label::before{content:'';width:24px;height:1px;background:var(--accent)}
.section-title{font-family:var(--font-display);font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.1;margin-bottom:20px}
.section-title span{color:var(--accent)}
.section-subtitle{color:var(--text2);font-size:1.05rem;max-width:620px;line-height:1.7}
.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:99px;font-weight:600;font-size:.92rem;transition:var(--transition);position:relative;overflow:hidden}
.btn-primary{background:var(--accent);color:var(--bg);box-shadow:0 0 40px rgba(200,255,0,.15)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 0 60px rgba(200,255,0,.3)}
.btn-outline{border:1.5px solid rgba(200,255,0,.35);color:var(--accent)}
.btn-outline:hover{background:rgba(200,255,0,.06);border-color:var(--accent)}
.btn-sm{padding:8px 18px;font-size:.8rem}
.fade-in{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}
.grid-cols-2{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.grid-cols-3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.grid-cols-4{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
@media(max-width:900px){.grid-cols-2,.grid-cols-3,.grid-cols-4{grid-template-columns:1fr}}
@media(min-width:601px) and (max-width:900px){.grid-cols-3,.grid-cols-4{grid-template-columns:1fr 1fr}}

/* ═══ TRUST BAR ═══ */
.trust-bar{background:var(–bg2);border-bottom:1px solid rgba(255,255,255,.04);padding:8px 0;font-size:.78rem;color:var(–text3)}
.trust-bar-inner{display:flex;align-items:center;justify-content:center;gap:24px;flex-wrap:wrap}
.trust-bar-item{display:flex;align-items:center;gap:6px}
.trust-bar-item .stars{color:var(–gold)}
.trust-bar-item strong{color:var(–text)}
.trust-bar-divider{width:1px;height:14px;background:rgba(255,255,255,.1)}
@media(max-width:600px){.trust-bar-divider:nth-child(4),.trust-bar-item:nth-child(n+4){display:none}}

/* ═══ NAV ═══ */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:14px 0;transition:var(–transition)}
.nav.scrolled{background:rgba(10,10,10,.94);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.04);padding:10px 0}
.nav-inner{display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:var(–font-display);font-size:1.4rem;font-weight:700;display:flex;align-items:center;gap:8px}
.nav-logo span{color:var(–accent)}
.nav-logo-icon{width:34px;height:34px;border:2px solid var(–accent);border-radius:8px;display:grid;place-items:center;font-size:.72rem;font-family:var(–font-mono);color:var(–accent);font-weight:700}
.nav-links{display:flex;align-items:center;gap:32px}
.nav-links a{font-size:.85rem;font-weight:500;color:var(–text2);transition:var(–transition);position:relative}
.nav-links a:hover{color:var(–text)}
.nav-links a::after{content:’’;position:absolute;bottom:-4px;left:0;width:0;height:1.5px;background:var(–accent);transition:width .3s}
.nav-links a:hover::after{width:100%}
.nav-cta{display:flex;align-items:center;gap:12px}
.nav-phone{display:flex;align-items:center;gap:6px;color:var(–accent);font-weight:600;font-size:.85rem}
.mobile-toggle{display:none;width:32px;height:32px;flex-direction:column;align-items:center;justify-content:center;gap:5px}
.mobile-toggle span{width:20px;height:2px;background:var(–text);border-radius:2px;transition:var(–transition)}
.mobile-menu{display:none;position:fixed;inset:0;background:rgba(10,10,10,.98);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:28px}
.mobile-menu.open{display:flex}
.mobile-menu a{font-size:1.3rem;font-weight:600;color:var(–text2)}
@media(max-width:1024px){.nav-links,.nav-cta .btn,.nav-phone{display:none}.mobile-toggle{display:flex}}

/* ═══ HERO ═══ */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding-top:120px;padding-bottom:60px}
.hero-bg{position:absolute;inset:0}
.hero-bg::before{content:’’;position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 70% 40%,rgba(200,255,0,.05),transparent),radial-gradient(ellipse 60% 50% at 20% 80%,rgba(0,180,216,.03),transparent),linear-gradient(180deg,transparent 60%,var(–bg));z-index:1}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(200,255,0,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(200,255,0,.025) 1px,transparent 1px);background-size:60px 60px;animation:gridDrift 20s linear infinite}
@keyframes gridDrift{to{transform:translate(60px,60px)}}
.hero-content{position:relative;z-index:2;max-width:720px}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(200,255,0,.07);border:1px solid rgba(200,255,0,.12);border-radius:99px;padding:6px 16px 6px 8px;font-size:.78rem;color:var(–accent);margin-bottom:24px}
.hero-badge-dot{width:8px;height:8px;background:var(–accent);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero h1{font-family:var(–font-display);font-size:clamp(2.8rem,5.5vw,4.6rem);line-height:1.08;margin-bottom:24px;font-weight:700}
.hero h1 em{color:var(–accent);font-style:italic}
.hero-desc{color:var(–text2);font-size:1.1rem;line-height:1.8;margin-bottom:32px;max-width:560px}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:40px}

/* Review aggregation bar */
.hero-reviews{display:flex;align-items:center;gap:20px;flex-wrap:wrap;margin-bottom:40px;padding:16px 20px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.05);border-radius:var(–radius)}
.hero-review-source{display:flex;align-items:center;gap:8px;font-size:.85rem}
.hero-review-source .stars{color:var(–gold);font-size:.8rem;letter-spacing:1px}
.hero-review-source .score{font-weight:700;font-family:var(–font-mono);color:var(–accent)}
.hero-review-source .count{color:var(–text3);font-size:.75rem}
.hero-review-source .platform{font-weight:600;color:var(–text2);font-size:.8rem}
.hero-review-divider{width:1px;height:24px;background:rgba(255,255,255,.08)}

.hero-stats{display:flex;gap:40px}
.hero-stat-num{font-size:2.2rem;font-weight:800;color:var(–accent);font-family:var(–font-mono)}
.hero-stat-label{font-size:.75rem;color:var(–text3);text-transform:uppercase;letter-spacing:.08em}

/* ═══ CERTIFICATION STRIP ═══ */
.cert-strip{padding:48px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.cert-strip-label{text-align:center;font-size:.72rem;text-transform:uppercase;letter-spacing:.15em;color:var(–text3);margin-bottom:24px}
.cert-logos{display:flex;align-items:center;justify-content:center;gap:40px;flex-wrap:wrap}
.cert-logo{display:flex;align-items:center;gap:8px;color:var(–text3);font-size:.8rem;font-weight:500;padding:10px 18px;border:1px solid rgba(255,255,255,.05);border-radius:99px;transition:var(–transition)}
.cert-logo:hover{border-color:rgba(200,255,0,.15);color:var(–text2)}
.cert-logo .icon{font-size:1.1rem}

/* ═══ WHY TRUST US ═══ */
.trust{background:var(–bg2)}
.trust-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:40px}
@media(max-width:900px){.trust-grid{grid-template-columns:1fr 1fr}}
@media(max-width:500px){.trust-grid{grid-template-columns:1fr}}
.trust-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);padding:28px;text-align:center;transition:var(–transition)}
.trust-card:hover{border-color:rgba(200,255,0,.12)}
.trust-card .num{font-size:2.2rem;font-weight:800;color:var(–accent);font-family:var(–font-mono);margin-bottom:4px}
.trust-card .label{font-size:.85rem;font-weight:600;margin-bottom:4px}
.trust-card .desc{font-size:.78rem;color:var(–text3);line-height:1.5}

/* ═══ LICENSE VERIFICATION ═══ */
.license-bar{margin-top:32px;padding:20px 28px;background:rgba(200,255,0,.04);border:1px solid rgba(200,255,0,.1);border-radius:var(–radius);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
.license-bar-info{display:flex;align-items:center;gap:12px}
.license-bar-icon{width:40px;height:40px;border-radius:10px;background:rgba(200,255,0,.1);display:grid;place-items:center;font-size:1.2rem}
.license-bar-text h4{font-size:.9rem;font-weight:600}
.license-bar-text p{font-size:.78rem;color:var(–text3)}
.license-bar a.btn{font-size:.8rem;padding:10px 20px}

/* ═══ SERVICES ═══ */
.services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:18px;margin-top:44px}
.service-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);padding:28px;transition:var(–transition);position:relative;overflow:hidden;cursor:pointer}
.service-card::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(–accent),transparent);opacity:0;transition:opacity .3s}
.service-card:hover{transform:translateY(-3px);border-color:rgba(200,255,0,.12);box-shadow:0 16px 50px rgba(0,0,0,.25)}
.service-card:hover::before{opacity:1}
.service-icon{width:48px;height:48px;border-radius:12px;display:grid;place-items:center;font-size:1.4rem;margin-bottom:16px}
.service-card h3{font-size:1.05rem;font-weight:700;margin-bottom:6px}
.service-card p{color:var(–text3);font-size:.85rem;line-height:1.6;margin-bottom:8px}
.service-price{font-family:var(–font-mono);font-size:.78rem;color:var(–accent);font-weight:500}
.service-card .arrow{position:absolute;bottom:20px;right:20px;width:28px;height:28px;border-radius:50%;border:1px solid rgba(255,255,255,.08);display:grid;place-items:center;color:var(–text3);transition:var(–transition);font-size:.8rem}
.service-card:hover .arrow{background:var(–accent);color:var(–bg);border-color:var(–accent)}
.si-1{background:rgba(200,255,0,.08);color:var(–accent)}
.si-2{background:rgba(255,107,53,.08);color:var(–warm)}
.si-3{background:rgba(0,180,216,.08);color:var(–blue)}
.si-4{background:rgba(155,93,229,.08);color:var(–violet)}
.si-5{background:rgba(255,214,10,.08);color:var(–gold)}

/* ═══ SERVICE AREAS ═══ */
.areas{background:var(–bg2)}
.areas-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-top:40px}
.area-card{padding:22px;border-radius:var(–radius);border:1px solid rgba(255,255,255,.04);background:var(–surface);text-align:center;transition:var(–transition)}
.area-card:hover{border-color:rgba(200,255,0,.15);transform:translateY(-2px)}
.area-card .ico{font-size:1.6rem;margin-bottom:8px}
.area-card h4{font-weight:600;font-size:.95rem;margin-bottom:2px}
.area-card p{color:var(–text3);font-size:.75rem;line-height:1.5}

/* ═══ HOW IT WORKS / PROJECT TIMELINE ═══ */
.timeline-track{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:48px;position:relative}
@media(max-width:768px){.timeline-track{grid-template-columns:1fr 1fr;gap:16px}}
@media(max-width:480px){.timeline-track{grid-template-columns:1fr}}
.timeline-step{text-align:center;position:relative;padding:0 16px}
.timeline-step::before{content:’’;position:absolute;top:24px;left:50%;right:-50%;height:2px;background:rgba(200,255,0,.12)}
.timeline-step:last-child::before{display:none}
.timeline-dot{width:48px;height:48px;border-radius:50%;background:rgba(200,255,0,.08);border:2px solid rgba(200,255,0,.2);display:grid;place-items:center;margin:0 auto 16px;font-size:1.2rem;position:relative;z-index:1}
.timeline-step h4{font-size:.9rem;font-weight:700;margin-bottom:4px}
.timeline-step p{font-size:.75rem;color:var(–text3);line-height:1.5}

/* ═══ AI TOOLS ═══ */
.ai-section{position:relative;overflow:hidden}
.ai-section::before{content:’’;position:absolute;inset:0;background:radial-gradient(ellipse 50% 40% at 50% 50%,rgba(200,255,0,.025),transparent)}
.ai-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:44px}
@media(max-width:900px){.ai-grid{grid-template-columns:1fr}}
.ai-disclaimer{margin-top:16px;padding:14px 18px;background:rgba(200,255,0,.04);border:1px solid rgba(200,255,0,.08);border-radius:var(–radius);font-size:.78rem;color:var(–text3);line-height:1.6;display:flex;align-items:flex-start;gap:8px}
.ai-disclaimer .icon{font-size:1rem;flex-shrink:0;margin-top:1px}

/* AI Chat */
.ai-chat-box{background:var(–surface);border:1px solid rgba(200,255,0,.08);border-radius:var(–radius-lg);overflow:hidden}
.ai-chat-header{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:center;gap:8px}
.ai-chat-header-dot{width:8px;height:8px;background:var(–accent);border-radius:50%;animation:pulse 2s infinite}
.ai-chat-header span{font-size:.82rem;font-weight:600}
.ai-chat-header .badge{font-size:.62rem;padding:2px 8px;background:rgba(200,255,0,.08);color:var(–accent);border-radius:99px;margin-left:auto}
.ai-chat-messages{padding:18px;height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:10px}
.ai-msg{max-width:85%;padding:11px 15px;border-radius:14px;font-size:.87rem;line-height:1.6;animation:msgIn .4s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.ai-msg.bot{background:var(–bg3);align-self:flex-start;border-bottom-left-radius:4px}
.ai-msg.user{background:rgba(200,255,0,.08);color:var(–accent);align-self:flex-end;border-bottom-right-radius:4px}
.ai-msg .typing{display:flex;gap:4px;padding:4px 0}
.ai-msg .typing span{width:6px;height:6px;background:var(–text3);border-radius:50%;animation:typingDot 1.4s infinite}
.ai-msg .typing span:nth-child(2){animation-delay:.2s}
.ai-msg .typing span:nth-child(3){animation-delay:.4s}
@keyframes typingDot{0%,60%,100%{opacity:.3;transform:translateY(0)}30%{opacity:1;transform:translateY(-4px)}}
.ai-quick-actions{display:flex;gap:6px;flex-wrap:wrap;padding:0 18px 8px}
.ai-quick-btn{padding:6px 12px;border-radius:99px;font-size:.72rem;border:1px solid rgba(200,255,0,.12);color:var(–accent);transition:var(–transition);cursor:pointer}
.ai-quick-btn:hover{background:rgba(200,255,0,.06)}
.ai-chat-input{display:flex;padding:10px 14px;border-top:1px solid rgba(255,255,255,.04);gap:8px}
.ai-chat-input input{flex:1;background:var(–bg3);border:1px solid rgba(255,255,255,.05);border-radius:99px;padding:10px 16px;color:var(–text);font-size:.82rem}
.ai-chat-input input::placeholder{color:var(–text3)}
.ai-chat-input button{width:38px;height:38px;border-radius:50%;background:var(–accent);color:var(–bg);display:grid;place-items:center;transition:var(–transition)}
.ai-human-handoff{padding:0 18px 14px;display:flex;align-items:center;gap:8px;font-size:.75rem;color:var(–text3)}
.ai-human-handoff a{color:var(–accent);font-weight:600}

/* AI Vision */
.ai-vision-box{background:var(–surface);border:1px solid rgba(155,93,229,.1);border-radius:var(–radius-lg);overflow:hidden}
.ai-vision-header{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:center;gap:8px}
.ai-vision-header-dot{width:8px;height:8px;background:var(–violet);border-radius:50%;animation:pulse 2s infinite}
.ai-vision-header span{font-weight:600;font-size:.82rem}
.ai-vision-header .badge{font-size:.62rem;padding:2px 8px;background:rgba(155,93,229,.08);color:var(–violet);border-radius:99px;margin-left:auto}
.ai-vision-body{padding:18px}
.ai-upload-zone{border:2px dashed rgba(155,93,229,.2);border-radius:var(–radius);padding:40px 20px;text-align:center;transition:var(–transition);cursor:pointer}
.ai-upload-zone:hover{border-color:var(–violet);background:rgba(155,93,229,.02)}
.ai-upload-zone .ico{font-size:2rem;margin-bottom:10px}
.ai-upload-zone h4{font-weight:600;font-size:.95rem;margin-bottom:2px}
.ai-upload-zone p{color:var(–text3);font-size:.78rem}
.ai-demo-btns{display:flex;gap:6px;margin-top:10px;flex-wrap:wrap}
.ai-vision-result{display:none;margin-top:14px}
.ai-vision-result.show{display:block}
.ai-vision-comparison{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.ai-vision-img{aspect-ratio:4/3;background:var(–bg3);border-radius:var(–radius);display:grid;place-items:center;position:relative;overflow:hidden}
.ai-vision-img .label{position:absolute;top:6px;left:6px;font-size:.62rem;padding:3px 8px;background:rgba(0,0,0,.7);border-radius:99px;color:var(–text2)}
.ai-cost-breakdown{background:var(–bg3);border-radius:var(–radius);padding:14px}
.ai-cost-breakdown h5{font-size:.75rem;color:var(–text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px}
.ai-cost-item{display:flex;justify-content:space-between;padding:5px 0;font-size:.82rem;border-bottom:1px solid rgba(255,255,255,.03)}
.ai-cost-item:last-child{border-bottom:none;font-weight:700;color:var(–accent)}

/* ═══ CALCULATOR ═══ */
.calc{background:var(–bg2)}
.calc-container{display:grid;grid-template-columns:1.2fr .8fr;gap:40px;margin-top:44px;align-items:start}
@media(max-width:900px){.calc-container{grid-template-columns:1fr}}

/* Multi-step form */
.calc-form{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);padding:32px}
.calc-steps-bar{display:flex;gap:4px;margin-bottom:24px}
.calc-step-dot{flex:1;height:3px;border-radius:99px;background:var(–bg3);transition:background .3s}
.calc-step-dot.active{background:var(–accent)}
.calc-step{display:none}
.calc-step.active{display:block}
.calc-step-title{font-size:1.05rem;font-weight:700;margin-bottom:4px}
.calc-step-desc{font-size:.82rem;color:var(–text3);margin-bottom:20px}
.calc-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
@media(max-width:600px){.calc-row{grid-template-columns:1fr}}
.calc-group{display:flex;flex-direction:column;gap:5px}
.calc-group label{font-size:.75rem;color:var(–text3);font-weight:500;text-transform:uppercase;letter-spacing:.04em}
.calc-group select,.calc-group input{background:var(–bg3);border:1px solid rgba(255,255,255,.05);border-radius:var(–radius);padding:11px 14px;color:var(–text);font-size:.87rem;transition:var(–transition)}
.calc-group select:focus,.calc-group input:focus{border-color:rgba(200,255,0,.25)}
.calc-group select option{background:var(–bg2)}
.calc-nav{display:flex;gap:10px;margin-top:20px}
.calc-nav .btn{flex:1;justify-content:center}
.calc-submit{width:100%;padding:14px;background:var(–accent);color:var(–bg);font-weight:700;font-size:.95rem;border-radius:var(–radius);transition:var(–transition)}
.calc-submit:hover{box-shadow:0 0 40px rgba(200,255,0,.15);transform:translateY(-2px)}
.calc-result{background:var(–surface);border:1px solid rgba(200,255,0,.08);border-radius:var(–radius-lg);padding:32px;display:none}
.calc-result.show{display:block}
.calc-result-label{font-size:.75rem;color:var(–text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px}
.calc-result-value{font-size:2.6rem;font-weight:800;color:var(–accent);font-family:var(–font-mono)}
.calc-result-range{color:var(–text3);font-size:.85rem;margin-top:6px}
.calc-result-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.calc-result-item:last-child{border-bottom:none}
.calc-result-item .l{color:var(–text2);font-size:.87rem}
.calc-result-item .v{font-weight:600;font-family:var(–font-mono);font-size:.87rem}
.calc-result-disclaimer{margin-top:16px;font-size:.75rem;color:var(–text3);padding:12px;background:rgba(200,255,0,.03);border-radius:8px;line-height:1.6}
.calc-financing{margin-top:16px;padding:14px;background:rgba(200,255,0,.04);border:1px solid rgba(200,255,0,.06);border-radius:var(–radius);display:flex;align-items:center;gap:10px}
.calc-financing .icon{font-size:1.3rem}
.calc-financing .text{font-size:.82rem;color:var(–text2)}
.calc-financing .text strong{color:var(–accent)}

/* ═══ CASE STUDIES ═══ */
.case-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:44px}
@media(max-width:768px){.case-grid{grid-template-columns:1fr}}
.case-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);overflow:hidden;transition:var(–transition)}
.case-card:hover{transform:translateY(-3px);border-color:rgba(200,255,0,.1)}
.case-card-img{aspect-ratio:16/9;background:linear-gradient(135deg,var(–bg3),var(–surface2));display:flex;align-items:center;justify-content:center;position:relative}
.case-card-img .emoji{font-size:3rem;opacity:.35}
.case-card-img .badge{position:absolute;top:10px;left:10px;font-size:.62rem;padding:4px 10px;background:rgba(200,255,0,.15);color:var(–accent);border-radius:99px;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.case-card-body{padding:22px}
.case-card-body h3{font-size:1.05rem;font-weight:700;margin-bottom:6px}
.case-meta{display:flex;gap:16px;margin-bottom:12px;flex-wrap:wrap}
.case-meta-item{display:flex;align-items:center;gap:4px;font-size:.78rem;color:var(–text3)}
.case-meta-item strong{color:var(–text2)}
.case-card-body p{font-size:.85rem;color:var(–text3);line-height:1.6;margin-bottom:12px}
.case-card-quote{font-style:italic;font-size:.85rem;color:var(–text2);padding:10px 14px;background:rgba(200,255,0,.03);border-left:2px solid var(–accent);border-radius:0 8px 8px 0;margin-top:8px}

/* ═══ TEAM ═══ */
.team{background:var(–bg2)}
.team-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:44px}
@media(max-width:900px){.team-grid{grid-template-columns:1fr 1fr}}
@media(max-width:500px){.team-grid{grid-template-columns:1fr}}
.team-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);padding:24px;text-align:center;transition:var(–transition)}
.team-card:hover{border-color:rgba(200,255,0,.12)}
.team-avatar{width:72px;height:72px;border-radius:50%;background:var(–bg3);margin:0 auto 14px;display:grid;place-items:center;font-size:1.5rem;font-weight:800;color:var(–accent);font-family:var(–font-mono);border:2px solid rgba(200,255,0,.1)}
.team-card h4{font-weight:700;font-size:.95rem;margin-bottom:2px}
.team-card .role{color:var(–accent);font-size:.78rem;font-weight:600;margin-bottom:8px}
.team-card .bio{color:var(–text3);font-size:.78rem;line-height:1.5}
.team-card .certs{margin-top:10px;display:flex;justify-content:center;gap:4px;flex-wrap:wrap}
.team-card .cert-tag{font-size:.62rem;padding:3px 8px;background:rgba(200,255,0,.06);border:1px solid rgba(200,255,0,.08);border-radius:99px;color:var(–accent)}

/* ═══ GOOGLE REVIEWS ═══ */
.reviews-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:8px}
.reviews-aggregate{display:flex;align-items:center;gap:12px}
.reviews-big-score{font-size:3.2rem;font-weight:900;color:var(–accent);font-family:var(–font-mono);line-height:1}
.reviews-stars{color:var(–gold);font-size:1.1rem;letter-spacing:2px}
.reviews-count{color:var(–text3);font-size:.85rem}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:32px}
@media(max-width:768px){.reviews-grid{grid-template-columns:1fr}}
.review-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);padding:24px;position:relative}
.review-card .g-icon{position:absolute;top:16px;right:16px;font-size:1rem;opacity:.3}
.review-card-header{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.review-card-avatar{width:36px;height:36px;border-radius:50%;background:var(–bg3);display:grid;place-items:center;font-size:.75rem;font-weight:700;color:var(–accent)}
.review-card-name{font-weight:600;font-size:.9rem}
.review-card-date{font-size:.7rem;color:var(–text3)}
.review-card-stars{color:var(–gold);font-size:.8rem;margin-bottom:8px}
.review-card-text{font-size:.87rem;color:var(–text2);line-height:1.7;font-style:italic}
.review-card-project{margin-top:8px;font-size:.72rem;color:var(–text3);font-weight:500}
.reviews-cta{text-align:center;margin-top:32px}

/* ═══ FAQ ═══ */
.faq{background:var(–bg2)}
.faq-grid{max-width:800px;margin:40px auto 0;display:flex;flex-direction:column;gap:8px}
.faq-item{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius);overflow:hidden;transition:var(–transition)}
.faq-item:hover{border-color:rgba(200,255,0,.08)}
.faq-q{padding:18px 22px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;font-weight:600;font-size:.95rem;gap:12px}
.faq-q .toggle{width:28px;height:28px;border-radius:50%;border:1px solid rgba(255,255,255,.08);display:grid;place-items:center;font-size:.8rem;color:var(–text3);transition:var(–transition);flex-shrink:0}
.faq-item.open .faq-q .toggle{background:var(–accent);color:var(–bg);border-color:var(–accent);transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .4s ease}
.faq-item.open .faq-a{max-height:300px;padding:0 22px 18px}
.faq-a p{color:var(–text3);font-size:.87rem;line-height:1.7}

/* ═══ BLOG ═══ */
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:44px}
@media(max-width:768px){.blog-grid{grid-template-columns:1fr}}
.blog-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);overflow:hidden;transition:var(–transition);cursor:pointer}
.blog-card:hover{transform:translateY(-3px);border-color:rgba(200,255,0,.08)}
.blog-card-img{aspect-ratio:16/9;background:var(–bg3);position:relative;display:grid;place-items:center}
.blog-card-img .emoji{font-size:2.2rem;opacity:.3}
.blog-card-category{position:absolute;top:10px;left:10px;font-size:.62rem;padding:4px 10px;background:rgba(0,0,0,.7);border-radius:99px;color:var(–accent);font-weight:600;text-transform:uppercase;letter-spacing:.06em}
.blog-card-body{padding:20px}
.blog-card-meta{font-size:.72rem;color:var(–text3);margin-bottom:6px;display:flex;gap:10px}
.blog-card-body h3{font-size:1rem;font-weight:700;margin-bottom:6px;line-height:1.35}
.blog-card-body p{color:var(–text3);font-size:.82rem;line-height:1.6}

/* ═══ WARRANTY / GUARANTEES ═══ */
.guarantee-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:44px}
@media(max-width:768px){.guarantee-grid{grid-template-columns:1fr}}
.guarantee-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius-lg);padding:28px;text-align:center;transition:var(–transition)}
.guarantee-card:hover{border-color:rgba(200,255,0,.12)}
.guarantee-card .ico{font-size:2rem;margin-bottom:12px}
.guarantee-card h4{font-weight:700;font-size:1rem;margin-bottom:4px}
.guarantee-card p{color:var(–text3);font-size:.82rem;line-height:1.6}

/* ═══ CONTACT ═══ */
.contact{background:var(–bg2)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:44px;margin-top:44px}
@media(max-width:900px){.contact-grid{grid-template-columns:1fr}}

/* Multi-step contact form */
.contact-form{display:flex;flex-direction:column;gap:14px}
.contact-steps{display:flex;gap:4px;margin-bottom:16px}
.contact-step-dot{flex:1;height:3px;border-radius:99px;background:var(–bg3);transition:background .3s}
.contact-step-dot.active{background:var(–accent)}
.contact-step{display:none}
.contact-step.active{display:block}
.contact-step-label{font-size:.95rem;font-weight:700;margin-bottom:4px}
.contact-step-desc{font-size:.78rem;color:var(–text3);margin-bottom:16px}
.contact-form input,.contact-form textarea,.contact-form select{background:var(–surface);border:1px solid rgba(255,255,255,.05);border-radius:var(–radius);padding:12px 16px;color:var(–text);font-size:.87rem;transition:var(–transition);width:100%}
.contact-form input:focus,.contact-form textarea:focus,.contact-form select:focus{border-color:rgba(200,255,0,.25)}
.contact-form textarea{min-height:100px;resize:vertical}
.contact-form select option{background:var(–bg2)}
.contact-service-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.contact-service-opt{padding:12px;border:1px solid rgba(255,255,255,.05);border-radius:var(–radius);text-align:center;font-size:.82rem;font-weight:500;cursor:pointer;transition:var(–transition);color:var(–text2)}
.contact-service-opt:hover,.contact-service-opt.selected{border-color:var(–accent);color:var(–accent);background:rgba(200,255,0,.04)}
.contact-info-cards{display:flex;flex-direction:column;gap:14px}
.contact-info-card{background:var(–surface);border:1px solid rgba(255,255,255,.04);border-radius:var(–radius);padding:20px;display:flex;gap:14px;align-items:flex-start;transition:var(–transition)}
.contact-info-card:hover{border-color:rgba(200,255,0,.1)}
.contact-info-icon{width:40px;height:40px;border-radius:10px;background:rgba(200,255,0,.06);color:var(–accent);display:grid;place-items:center;font-size:1.1rem;flex-shrink:0}
.contact-info-card h4{font-weight:600;font-size:.9rem;margin-bottom:1px}
.contact-info-card p{color:var(–text3);font-size:.82rem;line-height:1.5}
.contact-info-card a{color:var(–accent);font-weight:500}
.response-time{display:flex;align-items:center;gap:6px;padding:12px 16px;background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.12);border-radius:var(–radius);font-size:.8rem;color:var(–green);margin-top:8px}

/* ═══ FOOTER ═══ */
.footer{padding:80px 0 28px;border-top:1px solid rgba(255,255,255,.04)}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:40px;margin-bottom:48px}
@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr}}
.footer-brand{max-width:300px}
.footer-logo{font-family:var(–font-display);font-size:1.4rem;font-weight:700;margin-bottom:10px}
