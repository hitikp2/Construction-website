  <div class="phone-cta-text"><strong>Ready to start?</strong> Talk to our team now.</div>
  <div class="phone-cta-btns">
    <a href="tel:+18005551234" class="phone-cta-btn call">📞 Call</a>
    <a href="sms:+18005551234" class="phone-cta-btn text">💬 Text</a>
    <a href="https://wa.me/18005551234" class="phone-cta-btn whatsapp">WhatsApp</a>
