<!-- ═══ EXIT INTENT POPUP ═══ -->

<div class="exit-modal" id="exitModal">
  <div class="exit-modal-box">
    <button class="exit-modal-close" onclick="document.getElementById('exitModal').classList.remove('show')">×</button>
    <h3>Before you go —<br>get a <span>free estimate</span></h3>
    <p>Enter your info and we'll call you back within 5 minutes.</p>
    <div class="exit-modal-form">
      <input type="text" placeholder="Your Name">
      <input type="tel" placeholder="Phone Number">
      <select><option value="">What do you need?</option><option>Kitchen Remodel</option><option>Bathroom Remodel</option><option>Custom ADU</option><option>Room Addition</option><option>Painting</option><option>Commercial</option><option>Other</option></select>
      <button class="calc-submit" onclick="document.getElementById('exitModal').classList.remove('show');this.textContent='✓ We\'ll call you shortly!'">Get My Free Estimate →</button>
    </div>
  </div>
</div>

<script>
// ─── Nav scroll ───
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',scrollY>60);
  document.getElementById('phoneCta').classList.toggle('show',scrollY>600);
});

// ─── Scroll animations ───
const obs=new IntersectionObserver(e=>{e.forEach(el=>{if(el.isIntersecting)el.target.classList.add('visible')})},{threshold:.08});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

// ─── Counter ───
function animateCounters(){document.querySelectorAll('[data-count]').forEach(el=>{const t=parseInt(el.dataset.count);let c=0;const s=t/50;const i=setInterval(()=>{c+=s;if(c>=t){c=t;clearInterval(i)}el.textContent=Math.floor(c)},30)})}
setTimeout(animateCounters,800);

// ─── Exit intent ───
let exitShown=false;
document.addEventListener('mouseout',e=>{if(e.clientY<10&&!exitShown){exitShown=true;document.getElementById('exitModal').classList.add('show')}});

// ─── AI Chat ───
const aiResponses={
  kitchen:"A typical kitchen remodel in SoCal ranges from **$35,000–$120,000** depending on size and finishes. Our mid-range average is around **$65K** for a complete kitchen transformation. *Based on 2026 SoCal market rates from our project database.*",
  bathroom:"Bathroom remodels typically run **$15,000–$60,000**. Standard renovations average **$28K**, luxury spa-style can reach $60K+. *Data sourced from our 500+ completed SoCal projects.*",
  adu:"Custom ADUs in SoCal cost **$150,000–$350,000** for a fully permitted 400–1,200 sqft unit. We handle design, engineering, permits & construction. Most builds take 6–10 months. *San Bernardino County tends to be 10-15% less than LA/OC.*",
  permit:"We handle ALL permits for you. LA County currently runs 4–8 weeks for standard residential. We manage plan check, corrections, inspections & final sign-off. *You need permits for structural, electrical, or plumbing work in CA.*",
  financing:"Yes! We offer flexible financing from 12–120 months through our lending partners. A $60K kitchen = ~**$550/mo** with approved credit. *Ask during your free consultation for pre-qualification.*",
  default:"Great question! For the most accurate answer, I'd recommend scheduling a **free consultation** — call **(800) 555-1234** or fill out the form below. You can also try our **Instant Estimator** for a quick ballpark figure."
};
function sendAiMsg(){const i=document.getElementById('aiInput');const m=i.value.trim();if(!m)return;const c=document.getElementById('aiMessages');c.innerHTML+=`<div class="ai-msg user">${esc(m)}</div>`;i.value='';c.innerHTML+=`<div class="ai-msg bot" id="typing"><div class="typing"><span></span><span></span><span></span></div></div>`;c.scrollTop=c.scrollHeight;setTimeout(()=>{const t=document.getElementById('typing');if(t)t.remove();const l=m.toLowerCase();let r=aiResponses.default;if(l.includes('kitchen'))r=aiResponses.kitchen;else if(l.includes('bath'))r=aiResponses.bathroom;else if(l.includes('adu')||l.includes('accessory'))r=aiResponses.adu;else if(l.includes('permit'))r=aiResponses.permit;else if(l.includes('financ')||l.includes('payment')||l.includes('afford'))r=aiResponses.financing;c.innerHTML+=`<div class="ai-msg bot">${r}</div>`;c.scrollTop=c.scrollHeight},1200+Math.random()*600)}
function quickAsk(q){document.getElementById('aiInput').value=q;sendAiMsg()}
function esc(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML}

// ─── AI Vision ───
function handleUpload(e){if(e.target.files[0])demoVision('custom')}
function demoVision(t){const d={kitchen:{b:'🍳',a:'✨',items:[['Custom Cabinetry','$12,000–$18,000'],['Quartz Countertops','$4,500–$7,000'],['Backsplash Tile','$1,800–$3,200'],['Appliance Package','$5,000–$12,000'],['Plumbing & Electrical','$3,500–$6,000'],['Flooring','$2,800–$4,500'],['Labor & Management','$8,000–$14,000'],['TOTAL ESTIMATED','$37,600–$64,700']]},bathroom:{b:'🛁',a:'🪞',items:[['Tile (Floor + Walls)','$4,000–$8,000'],['Vanity + Mirror','$2,000–$5,500'],['Shower/Tub Fixtures','$1,500–$4,000'],['Plumbing','$2,000–$4,000'],['Lighting','$1,200–$2,500'],['Labor','$5,000–$8,000'],['TOTAL ESTIMATED','$15,700–$32,000']]},living:{b:'🛋️',a:'🌟',items:[['Hardwood Flooring','$5,000–$9,000'],['Built-In Shelving','$3,000–$6,000'],['Fireplace Reface','$2,500–$5,000'],['Accent Wall','$1,200–$2,800'],['Recessed Lighting','$1,800–$3,200'],['Labor','$4,000–$7,000'],['TOTAL ESTIMATED','$17,500–$33,000']]},custom:{b:'📸',a:'✨',items:[['Materials','$8,000–$15,000'],['Structural','$3,000–$8,000'],['Fixtures','$2,500–$6,000'],['MEP','$3,000–$5,500'],['Labor','$6,000–$10,000'],['Permits','$1,500–$3,000'],['TOTAL ESTIMATED','$24,000–$47,500']]}};const c=d[t];document.getElementById('beforeE').textContent=c.b;document.getElementById('afterE').textContent=c.a;let h=`<h5>AI Cost Breakdown</h5>`;c.items.forEach(([l,v])=>{h+=`<div class="ai-cost-item"><span>${l}</span><span>${v}</span></div>`});document.getElementById('costBreakdown').innerHTML=h;document.getElementById('visionResult').classList.add('show')}

// ─── Calculator (multi-step) ───
function calcNext(step){document.querySelectorAll('.calc-step').forEach(s=>s.classList.remove('active'));document.getElementById('calcStep'+step).classList.add('active');document.querySelectorAll('.calc-steps-bar .calc-step-dot').forEach((d,i)=>d.classList.toggle('active',i<step))}
const priceData={kitchen:{base:250,mid:350,premium:550},bathroom:{base:200,mid:300,premium:500},adu:{base:250,mid:350,premium:500},addition:{base:200,mid:300,premium:450},'painting-int':{base:3,mid:4.5,premium:6.5},'painting-ext':{base:4,mid:6,premium:9},roofing:{base:8,mid:12,premium:20},flooring:{base:8,mid:14,premium:25},outdoor:{base:50,mid:80,premium:140},commercial:{base:100,mid:175,premium:300},'full-remodel':{base:150,mid:250,premium:400}};
const countyMult={la:1.12,sb:1.0,oc:1.15,rv:.95};
function calculateEstimate(){const type=document.getElementById('calcType').value;const tier=document.getElementById('calcTier').value;const sqft=parseFloat(document.getElementById('calcSqft').value)||0;const county=document.getElementById('calcCounty').value;const rush=document.getElementById('calcTimeline').value==='rush';const permits=document.getElementById('calcPermits').value==='yes';if(!type||sqft<=0){alert('Please select a project type and enter square footage.');return}const d=priceData[type];let rate=d[tier==='standard'?'base':tier==='mid'?'mid':'premium'];let total=sqft*rate*countyMult[county];const mat=total*.4;const lab=total*.35;const oh=total*.15;let perm=permits?total*.08:0;const des=total*.02;if(rush)total*=1.15;total+=perm;const lo=Math.round(total*.85);const hi=Math.round(total*1.15);const mid=Math.round(total);const mo=Math.round(mid/120);document.getElementById('calcTotal').textContent='$'+mid.toLocaleString();document.getElementById('calcRange').textContent=`Range: $${lo.toLocaleString()} — $${hi.toLocaleString()}`;document.getElementById('calcMonthly').textContent='$'+mo.toLocaleString()+'/mo';document.getElementById('calcBreakdown').innerHTML=`<div class="calc-result-item"><span class="l">Materials & Finishes</span><span class="v">$${Math.round(mat).toLocaleString()}</span></div><div class="calc-result-item"><span class="l">Skilled Labor</span><span class="v">$${Math.round(lab).toLocaleString()}</span></div><div class="calc-result-item"><span class="l">Project Management</span><span class="v">$${Math.round(oh).toLocaleString()}</span></div><div class="calc-result-item"><span class="l">Design & Engineering</span><span class="v">$${Math.round(des).toLocaleString()}</span></div>${permits?`<div class="calc-result-item"><span class="l">Permits & Inspections</span><span class="v">$${Math.round(perm).toLocaleString()}</span></div>`:''}${rush?`<div class="calc-result-item"><span class="l">Rush Fee (15%)</span><span class="v">+$${Math.round(total*.13).toLocaleString()}</span></div>`:''}`;document.getElementById('calcResult').classList.add('show');document.getElementById('calcResult').scrollIntoView({behavior:'smooth',block:'nearest'})}

// ─── Contact form (multi-step) ───
function contactNext(step){document.querySelectorAll('.contact-step').forEach(s=>s.classList.remove('active'));document.getElementById('cStep'+step).classList.add('active');document.querySelectorAll('.contact-steps .contact-step-dot').forEach((d,i)=>d.classList.toggle('active',i<step))}
function toggleService(el){el.classList.toggle('selected')}
function submitContact(e){e.preventDefault();const btn=e.target;btn.textContent='✓ Submitted! We\'ll call within 2 hours.';btn.style.background='#22c55e';setTimeout(()=>{btn.textContent='Submit — Get Free Consultation →';btn.style.background=''},4000)}
</script>

</body>
